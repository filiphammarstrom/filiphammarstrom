generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  memberships   CompanyMember[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Company {
  id              String    @id @default(cuid())
  name            String
  orgNumber       String    @unique
  vatNumber       String?
  address         String?
  city            String?
  postalCode      String?
  email           String?
  phone           String?
  bankgiro        String?
  plusgiro        String?
  fiscalYearStart Int       @default(1)
  vatPeriod       VatPeriod @default(QUARTERLY)
  fTaxCertificate Boolean   @default(false)
  logoUrl         String?
  invoiceCounter  Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  members         CompanyMember[]
  customers       Customer[]
  suppliers       Supplier[]
  invoices        Invoice[]
  expenses        Expense[]
  journalEntries  JournalEntry[]
  accounts        ChartOfAccount[]
  bankConnections BankConnection[]
  vatReturns      VatReturn[]
  fiscalYears     FiscalYear[]
}

enum VatPeriod {
  MONTHLY
  QUARTERLY
  YEARLY
}

model CompanyMember {
  id        String     @id @default(cuid())
  companyId String
  userId    String
  role      MemberRole @default(MEMBER)
  createdAt DateTime   @default(now())
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([companyId, userId])
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  AUDITOR
}

model FiscalYear {
  id             String       @id @default(cuid())
  companyId      String
  startDate      DateTime
  endDate        DateTime
  closed         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  company        Company      @relation(fields: [companyId], references: [id])
  journalEntries JournalEntry[]
}

model ChartOfAccount {
  id            String      @id @default(cuid())
  companyId     String
  accountNumber Int
  name          String
  type          AccountType
  vatCode       String?
  isSystem      Boolean     @default(false)
  company       Company     @relation(fields: [companyId], references: [id])
  debitLines    JournalLine[] @relation("DebitAccount")
  creditLines   JournalLine[] @relation("CreditAccount")
  @@unique([companyId, accountNumber])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model Customer {
  id             String   @id @default(cuid())
  companyId      String
  name           String
  orgNumber      String?
  vatNumber      String?
  email          String?
  phone          String?
  address        String?
  city           String?
  postalCode     String?
  country        String   @default("SE")
  paymentTermDays Int     @default(30)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  company        Company  @relation(fields: [companyId], references: [id])
  invoices       Invoice[]
}

model Supplier {
  id        String   @id @default(cuid())
  companyId String
  name      String
  orgNumber String?
  vatNumber String?
  email     String?
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id])
  expenses  Expense[]
}

model Invoice {
  id             String        @id @default(cuid())
  companyId      String
  customerId     String
  invoiceNumber  String
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime      @default(now())
  dueDate        DateTime
  deliveryDate   DateTime?
  currency       String        @default("SEK")
  reverseCharge  Boolean       @default(false)
  buyerVatNumber String?
  subtotalSek    Decimal       @db.Decimal(12, 2)
  vatAmountSek   Decimal       @db.Decimal(12, 2)
  totalSek       Decimal       @db.Decimal(12, 2)
  paidAmountSek  Decimal       @db.Decimal(12, 2) @default(0)
  notes          String?
  ourReference   String?
  yourReference  String?
  sentAt         DateTime?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  company        Company       @relation(fields: [companyId], references: [id])
  customer       Customer      @relation(fields: [customerId], references: [id])
  lines          InvoiceLine[]
  journalEntries JournalEntry[]
  payments       Payment[]
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CREDITED
  CANCELLED
}

model InvoiceLine {
  id            String   @id @default(cuid())
  invoiceId     String
  description   String
  quantity      Decimal  @db.Decimal(10, 3)
  unitPrice     Decimal  @db.Decimal(12, 2)
  vatRate       Decimal  @db.Decimal(5, 2)
  vatAmount     Decimal  @db.Decimal(12, 2)
  lineTotal     Decimal  @db.Decimal(12, 2)
  accountNumber Int?
  unit          String?
  sortOrder     Int      @default(0)
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Expense {
  id               String        @id @default(cuid())
  companyId        String
  supplierId       String?
  status           ExpenseStatus @default(PENDING_REVIEW)
  source           ExpenseSource @default(MANUAL)
  rawImageUrl      String?
  rawEmailId       String?
  ocrData          Json?
  supplierName     String?
  invoiceNumber    String?
  issueDate        DateTime?
  dueDate          DateTime?
  currency         String        @default("SEK")
  subtotalSek      Decimal?      @db.Decimal(12, 2)
  vatAmountSek     Decimal?      @db.Decimal(12, 2)
  totalSek         Decimal?      @db.Decimal(12, 2)
  vatRate          Decimal?      @db.Decimal(5, 2)
  accountNumber    Int?
  description      String?
  reviewedAt       DateTime?
  reviewedByUserId String?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  company          Company       @relation(fields: [companyId], references: [id])
  supplier         Supplier?     @relation(fields: [supplierId], references: [id])
  journalEntries   JournalEntry[]
}

enum ExpenseStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  BOOKED
}

enum ExpenseSource {
  MANUAL
  PHOTO_OCR
  EMAIL_PARSED
  BANK_IMPORT
}

model JournalEntry {
  id              String        @id @default(cuid())
  companyId       String
  fiscalYearId    String?
  entryNumber     Int
  entryDate       DateTime
  description     String
  source          JournalSource
  invoiceId       String?
  expenseId       String?
  createdAt       DateTime      @default(now())
  createdByUserId String?
  company         Company       @relation(fields: [companyId], references: [id])
  fiscalYear      FiscalYear?   @relation(fields: [fiscalYearId], references: [id])
  invoice         Invoice?      @relation(fields: [invoiceId], references: [id])
  expense         Expense?      @relation(fields: [expenseId], references: [id])
  lines           JournalLine[]
}

enum JournalSource {
  INVOICE_CREATED
  INVOICE_PAID
  EXPENSE_BOOKED
  BANK_TRANSACTION
  MANUAL
  OPENING_BALANCE
}

model JournalLine {
  id              String          @id @default(cuid())
  journalEntryId  String
  debitAccountId  String?
  creditAccountId String?
  amountSek       Decimal         @db.Decimal(12, 2)
  description     String?
  vatCode         String?
  journalEntry    JournalEntry    @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  debitAccount    ChartOfAccount? @relation("DebitAccount", fields: [debitAccountId], references: [id])
  creditAccount   ChartOfAccount? @relation("CreditAccount", fields: [creditAccountId], references: [id])
}

model Payment {
  id          String        @id @default(cuid())
  invoiceId   String
  amount      Decimal       @db.Decimal(12, 2)
  paymentDate DateTime
  method      PaymentMethod
  reference   String?
  createdAt   DateTime      @default(now())
  invoice     Invoice       @relation(fields: [invoiceId], references: [id])
}

enum PaymentMethod {
  BANK_TRANSFER
  BANKGIRO
  SWISH
  CARD
  OTHER
}

model BankConnection {
  id             String            @id @default(cuid())
  companyId      String
  provider       String            @default("tink")
  accountId      String
  accountName    String
  iban           String?
  currency       String            @default("SEK")
  consentId      String?
  accessToken    String?           @db.Text
  refreshToken   String?           @db.Text
  tokenExpiresAt DateTime?
  lastSyncedAt   DateTime?
  createdAt      DateTime          @default(now())
  company        Company           @relation(fields: [companyId], references: [id])
  transactions   BankTransaction[]
}

model BankTransaction {
  id               String         @id @default(cuid())
  bankConnectionId String
  externalId       String
  transactionDate  DateTime
  bookingDate      DateTime?
  description      String
  amount           Decimal        @db.Decimal(12, 2)
  currency         String         @default("SEK")
  merchantName     String?
  category         String?
  reconciled       Boolean        @default(false)
  invoiceId        String?
  expenseId        String?
  bankConnection   BankConnection @relation(fields: [bankConnectionId], references: [id])
  @@unique([bankConnectionId, externalId])
}

model VatReturn {
  id             String          @id @default(cuid())
  companyId      String
  periodStart    DateTime
  periodEnd      DateTime
  status         VatReturnStatus @default(DRAFT)
  box05          Decimal         @db.Decimal(12, 2) @default(0)
  box06          Decimal         @db.Decimal(12, 2) @default(0)
  box07          Decimal         @db.Decimal(12, 2) @default(0)
  box10          Decimal         @db.Decimal(12, 2) @default(0)
  box11          Decimal         @db.Decimal(12, 2) @default(0)
  box12          Decimal         @db.Decimal(12, 2) @default(0)
  box30          Decimal         @db.Decimal(12, 2) @default(0)
  box49          Decimal         @db.Decimal(12, 2) @default(0)
  submittedAt    DateTime?
  skatteverketRef String?
  xmlPayload     String?         @db.Text
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  company        Company         @relation(fields: [companyId], references: [id])
}

enum VatReturnStatus {
  DRAFT
  READY
  SUBMITTED
  ACCEPTED
  REJECTED
}
